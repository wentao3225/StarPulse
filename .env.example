# 复制此文件为 .env 并填入以下配置

# GitHub Token（提高 API 速率限制）
# 申请地址：https://github.com/settings/tokens（无需任何权限，public 访问即可）
GITHUB_TOKEN=your_github_token_here

# 飞书应用配置（用于写入多维表格）
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_BITABLE_APP_TOKEN=your_bitable_app_token

# DeepSeek API Key（用于 AI 生成仓库解读）
# 申请地址：https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key

# QQ 邮箱配置（用于每日资讯推送，--news 参数启用时必填）
# QQ_SMTP_PASSWORD 是授权码，不是登录密码
# 开启方式：QQ邮箱 → 设置 → 账户 → POP3/SMTP服务 → 开启 → 生成授权码
QQ_EMAIL=your_qq_email@qq.com
QQ_SMTP_PASSWORD=your_qq_smtp_authorization_code
